# Release signing for Google Play. Copy this file to `keystore.properties` (which is gitignored) and
# fill in your upload-key details. The real file and any *.jks/*.keystore are never committed.
#
# Generate an upload keystore first (run from the repo root):
#
#   keytool -genkeypair -v \
#     -keystore telecampro-upload.jks \
#     -alias telecampro \
#     -keyalg RSA -keysize 4096 -validity 10000
#
# keytool prompts for the store/key password and your name/org (self-signed is fine — Google's Play
# App Signing holds the real app-signing key; this is only your *upload* key). Then set the values
# below. `storeFile` is resolved relative to the repo root.

storeFile=telecampro-upload.jks
storePassword=CHANGE_ME
keyAlias=telecampro
keyPassword=CHANGE_ME
